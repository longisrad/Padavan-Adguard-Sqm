### Target Vendor/Product (support only Ralink RT3883/MT7620/MT7621/MT7628)
CONFIG_VENDOR=NEWIFI
CONFIG_PRODUCT=MT7621

### Target ProductID (board select, max 12 symbols)
CONFIG_FIRMWARE_PRODUCT_ID="NEWIFI-D2"

############################################################
### Linux kernel configuration
############################################################

### Force MT7621 CPU clock to 900MHz
CONFIG_FIRMWARE_CPU_900MHZ=y

### Enable MT7621 CPU sleep mode (downclock to 220MHz on idle)
CONFIG_FIRMWARE_CPU_SLEEP=y

### Kernel driver select for WiFi AP 2.4GHz (BẮT BUỘC)
CONFIG_FIRMWARE_WIFI2_DRIVER=4.1

### Kernel driver select for WiFi AP 5GHz (BẮT BUỘC)
CONFIG_FIRMWARE_WIFI5_DRIVER=3.0

### Enable IPv6 support ~0.2MB
CONFIG_FIRMWARE_ENABLE_IPV6=y

### Include XFRM (IPsec) modules ~0.2MB (cần cho AmneziaWG)
CONFIG_FIRMWARE_INCLUDE_XFRM=y

### Enable USB support (BẮT BUỘC - USB 4G + ổ cứng)
CONFIG_FIRMWARE_ENABLE_USB=y

### Include file system utilities (BẮT BUỘC)
CONFIG_FIRMWARE_INCLUDE_FS_TOOLS=y

### NTFS via Paragon ufsd ~0.4MB (ổ cứng NTFS)
CONFIG_FIRMWARE_ENABLE_UFSD=y

### FAT32 ~0.1MB (USB 4G modem cần)
CONFIG_FIRMWARE_ENABLE_FAT=y

### exFAT ~0.12MB
CONFIG_FIRMWARE_ENABLE_EXFAT=y

### EXT4 ~0.4MB (ổ cứng Linux)
CONFIG_FIRMWARE_ENABLE_EXT4=y

### FUSE ~0.1MB (cần cho một số filesystem tools)
CONFIG_FIRMWARE_ENABLE_FUSE=y

### Swap support ~0.05MB (tối ưu RAM - dùng swap trên ổ cứng USB)
CONFIG_FIRMWARE_ENABLE_SWAP=y

### UVC camera - TẮT (không dùng)
#CONFIG_FIRMWARE_INCLUDE_UVC=y

### Network QoS modules ~0.2MB (BẮT BUỘC cho SQM)
CONFIG_FIRMWARE_INCLUDE_QOS=y

### IFB module ~0.03MB (BẮT BUỘC cho SQM ingress shaping)
CONFIG_FIRMWARE_INCLUDE_IFB=y

### TPROXY ~0.005MB
CONFIG_FIRMWARE_INCLUDE_TPROXY=y

### IPSet ~0.4MB (cần cho AdGuardHome + firewall)
CONFIG_FIRMWARE_INCLUDE_IPSET=y

### NFS server - TẮT (không dùng)
#CONFIG_FIRMWARE_INCLUDE_NFSD=y

### NFS client - TẮT
#CONFIG_FIRMWARE_INCLUDE_NFSC=y

### CIFS client - TẮT
#CONFIG_FIRMWARE_INCLUDE_CIFS=y

### Shortcut Forward Engine (tăng tốc NAT phần cứng)
CONFIG_FIRMWARE_INCLUDE_SHORTCUT_FE=y

############################################################
### Userspace configuration
############################################################

### Ngôn ngữ - chỉ giữ EN (mặc định)
#CONFIG_FIRMWARE_INCLUDE_LANG_RU=y

### Router vendor icon
CONFIG_FIRMWARE_INCLUDE_VENDOR_LOGO=y

### Optimize for size (giảm ~5-10% firmware size)
CONFIG_CC_OPTIMIZE_FOR_SIZE=y

### dnsmasq regex
CONFIG_FIRMWARE_ENABLE_DNSMASQ_REGEX=y

### Printer daemon - TẮT
#CONFIG_FIRMWARE_INCLUDE_LPRD=y

### USB-over-Ethernet printer - TẮT
#CONFIG_FIRMWARE_INCLUDE_U2EC=y

### tcpdump - TẮT (debug tool, không cần production)
#CONFIG_FIRMWARE_INCLUDE_TCPDUMP=y

### hdparm ~0.1MB (quản lý HDD spindown - GIỮ cho ổ cứng)
CONFIG_FIRMWARE_INCLUDE_HDPARM=y

### parted ~0.3MB (GPT partition - GIỮ cho ổ cứng lớn)
CONFIG_FIRMWARE_INCLUDE_PARTED=y

### SMB server - TẮT (tiết kiệm ~0.8MB RAM)
#CONFIG_FIRMWARE_INCLUDE_SMBD=y
#CONFIG_FIRMWARE_INCLUDE_SMBD36=y

### WINS - TẮT
#CONFIG_FIRMWARE_INCLUDE_WINS=y

### FTP server - TẮT
#CONFIG_FIRMWARE_INCLUDE_FTPD=y

### RPL2TP - TẮT
#CONFIG_FIRMWARE_INCLUDE_RPL2TP=y

### EAP-PEAP - TẮT (không dùng 802.1X)
#CONFIG_FIRMWARE_INCLUDE_EAP_PEAP=y

### DDNS SSL ~1.2MB openssl (GIỮ nếu dùng DDNS)
CONFIG_FIRMWARE_INCLUDE_DDNS_SSL=y

### HTTPS ~1.2MB openssl (BẮT BUỘC cho web UI HTTPS)
CONFIG_FIRMWARE_INCLUDE_HTTPS=y

### SFTP - TẮT
#CONFIG_FIRMWARE_INCLUDE_SFTP=y

### Dropbear SSH ~0.3MB (GIỮ để quản lý từ xa)
CONFIG_FIRMWARE_INCLUDE_DROPBEAR=y
CONFIG_FIRMWARE_INCLUDE_DROPBEAR_FAST_CODE=y

### OpenSSH - TẮT (dùng dropbear nhẹ hơn)
#CONFIG_FIRMWARE_INCLUDE_OPENSSH=y

### OpenVPN - TẮT (tiết kiệm ~0.4MB)
#CONFIG_FIRMWARE_INCLUDE_OPENVPN=y

### StrongSwan - TẮT (tiết kiệm ~0.7MB)
#CONFIG_FIRMWARE_INCLUDE_SSWAN=y

### AmneziaWG ~0.11MB (GIỮ - nhẹ, hữu ích)
CONFIG_FIRMWARE_INCLUDE_AMNEZIAWG=y

### WireGuard - TẮT (dùng AmneziaWG thay)
#CONFIG_FIRMWARE_INCLUDE_WIREGUARD=y

### OpenSSL EC ~0.1MB
CONFIG_FIRMWARE_INCLUDE_OPENSSL_EC=y

### OpenSSL executable - TẮT (chỉ cần library, không cần binary)
#CONFIG_FIRMWARE_INCLUDE_OPENSSL_EXE=y

### xUPNPd IPTV - TẮT
#CONFIG_FIRMWARE_INCLUDE_XUPNPD=y

### Minidlna - TẮT (nặng RAM ~1.6MB)
#CONFIG_FIRMWARE_INCLUDE_MINIDLNA=y

### Transmission - TẮT (nặng ~1.5MB)
#CONFIG_FIRMWARE_INCLUDE_TRANSMISSION=y
#CONFIG_FIRMWARE_INCLUDE_TRANSMISSION_WEB_CONTROL=y

### Aria2 - TẮT (nặng ~3.5MB)
#CONFIG_FIRMWARE_INCLUDE_ARIA=y
#CONFIG_FIRMWARE_INCLUDE_ARIA_WEB_CONTROL=y

### TOR - TẮT
#CONFIG_FIRMWARE_INCLUDE_TOR=y
#CONFIG_FIRMWARE_INCLUDE_TOR_GEOIP=y

### Privoxy - TẮT
#CONFIG_FIRMWARE_INCLUDE_PRIVOXY=y

### DNSCrypt ~0.5MB (TẮT - dùng AGH thay)
#CONFIG_FIRMWARE_INCLUDE_DNSCRYPT=y

### Stubby DoT - TẮT (dùng AGH thay)
#CONFIG_FIRMWARE_INCLUDE_STUBBY=y

### DoH proxy - TẮT (dùng AGH thay)
#CONFIG_FIRMWARE_INCLUDE_DOH=y

### Curl ~0.15MB (GIỮ - nhiều script cần)
CONFIG_FIRMWARE_INCLUDE_CURL=y

### QUIC trong Curl - TẮT (không cần)
#CONFIG_FIRMWARE_INCLUDE_QUIC=y

### WPAD - TẮT
#CONFIG_FIRMWARE_INCLUDE_WPAD=y

### ZRAM ~compressed memory (BẮT BUỘC - tối ưu RAM 512MB)
CONFIG_FIRMWARE_INCLUDE_ZRAM=y

### ADB - TẮT
#CONFIG_FIRMWARE_INCLUDE_ADB=y

### LUA ~0.2MB - TẮT
#CONFIG_FIRMWARE_INCLUDE_LUA=y

### EoIP ~0.01MB - TẮT
#CONFIG_FIRMWARE_INCLUDE_EOIP=y

### Zapret - TẮT (không cần bypass)
#CONFIG_FIRMWARE_INCLUDE_ZAPRET=y
#CONFIG_FIRMWARE_INCLUDE_ZAPRET2=y

### iPerf3 - TẮT
#CONFIG_FIRMWARE_INCLUDE_IPERF3=y

### redsocks2 - TẮT
#CONFIG_FIRMWARE_INCLUDE_REDSOCKS2=y

### ZeroTier - TẮT
#CONFIG_FIRMWARE_INCLUDE_ZEROTIER=y

### Shadowsocks - TẮT
#CONFIG_FIRMWARE_INCLUDE_SSREDIR=y
#CONFIG_FIRMWARE_INCLUDE_SSLOCAL=y

### AdGuardHome ~5MB (BẮT BUỘC GIỮ)
CONFIG_FIRMWARE_INCLUDE_AGH=y

### SQM Smart Queue Management (BẮT BUỘC GIỮ)
CONFIG_FIRMWARE_SQM_UI=y
