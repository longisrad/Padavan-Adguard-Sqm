### Target Vendor/Product
CONFIG_VENDOR=NEWIFI
CONFIG_PRODUCT=MT7621
CONFIG_FIRMWARE_PRODUCT_ID="NEWIFI-D2"

# --- Giao diện và Ngôn ngữ ---
CONFIG_FIRMWARE_SET_BYTEORDER=MIPSEL
CONFIG_FIRMWARE_WEBUI_LUA=y
CONFIG_FIRMWARE_INCLUDE_LANG_BR=n
CONFIG_FIRMWARE_INCLUDE_LANG_CZ=n
CONFIG_FIRMWARE_INCLUDE_LANG_DA=n
CONFIG_FIRMWARE_INCLUDE_LANG_DE=n
CONFIG_FIRMWARE_INCLUDE_LANG_ES=n
CONFIG_FIRMWARE_INCLUDE_LANG_FI=n
CONFIG_FIRMWARE_INCLUDE_LANG_FR=n
CONFIG_FIRMWARE_INCLUDE_LANG_NO=n
CONFIG_FIRMWARE_INCLUDE_LANG_PL=n
CONFIG_FIRMWARE_INCLUDE_LANG_RU=n
CONFIG_FIRMWARE_INCLUDE_LANG_SV=n
CONFIG_FIRMWARE_INCLUDE_LANG_UK=n
CONFIG_FIRMWARE_INCLUDE_LANG_ZH=n

# --- IPv6 & Mạng cơ bản ---
CONFIG_FIRMWARE_INCLUDE_IPV6=y
CONFIG_FIRMWARE_INCLUDE_HTTPS=y

# --- TỐI ƯU HIỆU NĂNG & SQM QoS (BẮT BUỘC GIỮ) ---
CONFIG_FIRMWARE_INCLUDE_STC=y
CONFIG_FIRMWARE_INCLUDE_KMS=n
CONFIG_FIRMWARE_INCLUDE_SFE=y
CONFIG_FIRMWARE_INCLUDE_SQM=y
CONFIG_FIRMWARE_INCLUDE_SQM_CAKE=y

# --- HỖ TRỢ USB, Ổ CỨNG VÀ USB 4G (BẮT BUỘC GIỮ) ---
CONFIG_FIRMWARE_ENABLE_USB=y
CONFIG_FIRMWARE_ENABLE_E_STORAGE=y
CONFIG_FIRMWARE_ENABLE_EXT2=y
CONFIG_FIRMWARE_ENABLE_EXT3=y
CONFIG_FIRMWARE_ENABLE_EXT4=y
CONFIG_FIRMWARE_ENABLE_FAT=y
CONFIG_FIRMWARE_ENABLE_EXFAT=y
CONFIG_FIRMWARE_ENABLE_NTFS=y
CONFIG_FIRMWARE_INCLUDE_XFS=n
CONFIG_FIRMWARE_INCLUDE_FUSE=y
CONFIG_FIRMWARE_INCLUDE_WDD=y

# --- DRIVER USB 4G MODEM ---
CONFIG_FIRMWARE_INCLUDE_MODEM=y
CONFIG_FIRMWARE_INCLUDE_MODEM_NCM=y
CONFIG_FIRMWARE_INCLUDE_MODEM_QMI=y

# --- TẮT CÁC DỊCH VỤ ĐỂ TIẾT KIỆM RAM/CPU ---
CONFIG_FIRMWARE_INCLUDE_SHADOWSOCKS=n
CONFIG_FIRMWARE_INCLUDE_SSSERVER=n
CONFIG_FIRMWARE_INCLUDE_V2RAY=n
CONFIG_FIRMWARE_INCLUDE_TROJAN=n
CONFIG_FIRMWARE_INCLUDE_KOOLPROXY=n
CONFIG_FIRMWARE_INCLUDE_CADDY=n
CONFIG_FIRMWARE_INCLUDE_CADDYINDEX=n
CONFIG_FIRMWARE_INCLUDE_ADGUARDHOME=y
CONFIG_FIRMWARE_INCLUDE_FRPC=n
CONFIG_FIRMWARE_INCLUDE_FRPS=n
CONFIG_FIRMWARE_INCLUDE_ALIDDNS=n
CONFIG_FIRMWARE_INCLUDE_ZEROTIER=n
CONFIG_FIRMWARE_INCLUDE_WIND=n
CONFIG_FIRMWARE_INCLUDE_SMARTDNS=n
CONFIG_FIRMWARE_INCLUDE_TUNSAFE=n
CONFIG_FIRMWARE_INCLUDE_WIREGUARD=n

# Tắt Share file nội bộ qua Router (nên cấu hình trên thiết bị đầu cuối/NAS thay vì Router)
CONFIG_FIRMWARE_INCLUDE_S_STORAGE=n
CONFIG_FIRMWARE_INCLUDE_FTPD=n
CONFIG_FIRMWARE_INCLUDE_FTPD_SSL=n
CONFIG_FIRMWARE_INCLUDE_SAMBA=n
CONFIG_FIRMWARE_INCLUDE_SAMBA36=n
CONFIG_FIRMWARE_INCLUDE_WINS=n
CONFIG_FIRMWARE_INCLUDE_SYSLOG=y

# Tắt Multimedia & Download Client (Nặng CPU/RAM nhất)
CONFIG_FIRMWARE_INCLUDE_MINIDLNA=n
CONFIG_FIRMWARE_INCLUDE_FIREFLY=n
CONFIG_FIRMWARE_INCLUDE_TRANSMISSION=n
CONFIG_FIRMWARE_INCLUDE_TRANSMISSION_WEB_CONTROL=n
CONFIG_FIRMWARE_INCLUDE_ARIA=n
CONFIG_FIRMWARE_INCLUDE_ARIA_WEB_CONTROL=n

# Tắt VPN Server/Client tích hợp (Nếu cần, chạy trên thiết bị mạng phía sau tốt hơn)
CONFIG_FIRMWARE_INCLUDE_OPENVPN=n
CONFIG_FIRMWARE_INCLUDE_PPTP=n
CONFIG_FIRMWARE_INCLUDE_L2TP=n

# Tắt các tính năng bổ trợ không dùng đến
CONFIG_FIRMWARE_INCLUDE_PRINTER=n
CONFIG_FIRMWARE_INCLUDE_DUMPE2FS=n
CONFIG_FIRMWARE_INCLUDE_RTL_SDR=n
CONFIG_FIRMWARE_INCLUDE_MTR=n
CONFIG_FIRMWARE_INCLUDE_NMAP=n
CONFIG_FIRMWARE_INCLUDE_IPERF3=n
CONFIG_FIRMWARE_INCLUDE_TCPDUMP=n

# --- CẤU HÌNH PHẦN CỨNG CHI TIẾT ---
CONFIG_FIRMWARE_INCLUDE_MT76X2_AP=y
CONFIG_FIRMWARE_CRYPTO_HW=y
CONFIG_FIRMWARE_CPU_SLEEP=y
